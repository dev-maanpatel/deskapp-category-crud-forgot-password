<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title><%= title %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1" />
    <link rel="stylesheet" type="text/css" href="/vendors/styles/core.css" />
    <link rel="stylesheet" type="text/css" href="/vendors/styles/icon-font.min.css" />
    <link rel="stylesheet" type="text/css" href="/vendors/styles/style.css" />
    <link rel="stylesheet" type="text/css" href="/vendors/styles/password-toggle.css" />
</head>
<body class="login-page">
    <div class="login-header box-shadow">
        <div class="container-fluid d-flex justify-content-between align-items-center">
            <div class="brand-logo">
                <a href="/signin"><img src="/vendors/images/deskapp-logo.svg" alt="DeskApp" /></a>
            </div>
            <div class="login-menu"><ul><li><a href="/signin">Login</a></li></ul></div>
        </div>
    </div>

    <div class="login-wrap d-flex align-items-center flex-wrap justify-content-center">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6 col-lg-7"><img src="/vendors/images/login-page-img.png" alt="Reset Password" /></div>
                <div class="col-md-6 col-lg-5">
                    <div class="login-box bg-white box-shadow border-radius-10">
                        <div class="login-title">
                            <h2 class="text-center text-primary">Reset Password</h2>
                        </div>
                        <% if (email) { %>
                            <p class="text-center text-muted mb-20">Set new password for <strong><%= email %></strong></p>
                        <% } %>

                        <% if (error) { %>
                            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                <%= error %>
                                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                                    <span aria-hidden="true">&times;</span>
                                </button>
                            </div>
                        <% } %>

                        <form action="/reset-password" method="post">
                            <input type="hidden" name="userId" value="<%= userId %>" />
                            <div class="input-group custom password-toggle-group">
                                <input type="password" id="resetNewPassword" name="newPassword" class="form-control form-control-lg" placeholder="New Password" required />
                                <div class="input-group-append custom">
                                    <span class="input-group-text password-toggle-btn" data-target="resetNewPassword"><i class="fa fa-eye"></i></span>
                                </div>
                            </div>
                            <div class="input-group custom password-toggle-group">
                                <input type="password" id="resetConfirmPassword" name="confirmPassword" class="form-control form-control-lg" placeholder="Confirm Password" required />
                                <div class="input-group-append custom">
                                    <span class="input-group-text password-toggle-btn" data-target="resetConfirmPassword"><i class="fa fa-eye"></i></span>
                                </div>
                            </div>
                            <p class="text-muted font-13 mb-20">Password must be 8 to 15 characters with one capital letter and one special character.</p>
                            <div class="row">
                                <div class="col-sm-12">
                                    <button class="btn btn-primary btn-lg btn-block" type="submit">Update Password</button>
                                </div>
                            </div>
                            <div class="text-center mt-20 pt-10 ">
                                <a href="/forgot-password">Use another email</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="/vendors/scripts/core.js"></script>
    <script src="/vendors/scripts/script.min.js"></script>
    <script src="/vendors/scripts/password-toggle.js"></script>
</body>
</html>
