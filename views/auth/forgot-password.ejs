<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title><%= title %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1" />
    <link rel="stylesheet" type="text/css" href="/vendors/styles/core.css" />
    <link rel="stylesheet" type="text/css" href="/vendors/styles/icon-font.min.css" />
    <link rel="stylesheet" type="text/css" href="/vendors/styles/style.css" />
    <style>
        .otp-modal-backdrop {
            position: fixed;
            inset: 0;
            z-index: 9998;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
            background: rgba(20, 28, 45, 0.62);
        }
        .otp-modal-card {
            width: 100%;
            max-width: 460px;
            position: relative;
            z-index: 9999;
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.22);
            padding: 30px;
        }
        .otp-icon {
            width: 68px;
            height: 68px;
            margin: 0 auto 18px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 30px;
            color: #1b00ff;
            background: rgba(27, 0, 255, 0.09);
        }
        .otp-input {
            height: 56px;
            text-align: center;
            font-size: 24px;
            font-weight: 600;
            letter-spacing: 10px;
        }
        .resend-row {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 6px;
            min-height: 38px;
        }
        .resend-button {
            border: 0;
            padding: 0;
            color: #1b00ff;
            background: transparent;
            font-weight: 600;
            cursor: pointer;
        }
        .resend-button:disabled {
            color: #98a0ad;
            cursor: not-allowed;
        }
        .otp-modal-close {
            position: absolute;
            top: 12px;
            right: 16px;
            border: 0;
            background: transparent;
            font-size: 28px;
            line-height: 1;
            color: #777;
            cursor: pointer;
        }
    </style>
</head>
<body class="login-page">
    <div class="login-header box-shadow">
        <div class="container-fluid d-flex justify-content-between align-items-center">
            <div class="brand-logo">
                <a href="/signin"><img src="/vendors/images/deskapp-logo.svg" alt="DeskApp" /></a>
            </div>
            <div class="login-menu"><ul><li><a href="/signin">Login</a></li></ul></div>
        </div>
    </div>

    <div class="login-wrap d-flex align-items-center flex-wrap justify-content-center">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6 col-lg-7"><img src="/vendors/images/login-page-img.png" alt="Forgot Password" /></div>
                <div class="col-md-6 col-lg-5">
                    <div class="login-box bg-white box-shadow border-radius-10">
                        <div class="login-title">
                            <h2 class="text-center text-primary">Forgot Password</h2>
                        </div>
                        <p class="text-center text-muted mb-25">Enter your registered email to generate a verification OTP.</p>

                        <% if (error && !showOtpModal) { %>
                            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                <%= error %>
                                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                                    <span aria-hidden="true">&times;</span>
                                </button>
                            </div>
                        <% } %>

                        <% if (success && !showOtpModal) { %>
                            <div class="alert alert-success alert-dismissible fade show" role="alert">
                                <%= success %>
                                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                                    <span aria-hidden="true">&times;</span>
                                </button>
                            </div>
                        <% } %>

                        <form action="/forgot-password" method="post">
                            <div class="input-group custom">
                                <input type="email" name="email" class="form-control form-control-lg" placeholder="Registered Email" value="<%= email || '' %>" required />
                                <div class="input-group-append custom">
                                    <span class="input-group-text"><i class="icon-copy dw dw-email1"></i></span>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-sm-12">
                                    <button class="btn btn-primary btn-lg btn-block" type="submit">Generate OTP</button>
                                </div>
                            </div>
                            <div class="text-center mt-20 pt-10">
                                <a href="/signin">Back to login</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <% if (showOtpModal) { %>
        <div class="otp-modal-backdrop" id="otpModal">
            <div class="otp-modal-card">
                <button type="button" class="otp-modal-close" id="closeOtpModal" aria-label="Close">&times;</button>
                <div class="otp-icon"><i class="dw dw-lock"></i></div>
                <h3 class="text-center mb-10">Verify OTP</h3>
                <p class="text-center text-muted mb-20">
                    Enter the 6-digit OTP generated for <strong><%= email %></strong>.
                    For testing, the OTP is displayed in the server console.
                </p>

                <% if (error) { %>
                    <div class="alert alert-danger" role="alert"><%= error %></div>
                <% } %>

                <% if (success) { %>
                    <div class="alert alert-success" role="alert"><%= success %></div>
                <% } %>

                <form action="/verify-otp" method="post">
                    <input type="hidden" name="otpIdentity" value="<%= otpIdentity %>" />
                    <div class="form-group mb-20">
                        <input
                            type="text"
                            name="otp"
                            class="form-control otp-input"
                            placeholder="000000"
                            inputmode="numeric"
                            pattern="[0-9]{6}"
                            maxlength="6"
                            autocomplete="one-time-code"
                            required
                        />
                    </div>
                    <button class="btn btn-primary btn-lg btn-block" type="submit">Verify OTP</button>
                </form>

                <div class="resend-row mt-20">
                    <span id="timerText" class="text-muted">Resend OTP in <strong id="otpTimer">30</strong>s</span>
                    <form action="/resend-otp" method="post" id="resendForm" style="display:inline;">
                        <input type="hidden" name="otpIdentity" value="<%= otpIdentity %>" />
                        <button type="submit" class="resend-button" id="resendButton" disabled>Resend OTP</button>
                    </form>
                </div>
            </div>
        </div>
    <% } %>

    <script src="/vendors/scripts/core.js"></script>
    <script src="/vendors/scripts/script.min.js"></script>
    <% if (showOtpModal) { %>
        <script>
            (function () {
                const otpExpiresAt = Number(<%- JSON.stringify(otpExpiresAt || 0) %>);
                const otpResendAt = Number(<%- JSON.stringify(otpResendAt || 0) %>);
                const timerElement = document.getElementById("otpTimer");
                const timerText = document.getElementById("timerText");
                const resendButton = document.getElementById("resendButton");
                const closeButton = document.getElementById("closeOtpModal");
                const modal = document.getElementById("otpModal");

                function updateTimer() {
                    const resendSecondsLeft = Math.max(0, Math.ceil((otpResendAt - Date.now()) / 1000));
                    const otpSecondsLeft = Math.max(0, Math.ceil((otpExpiresAt - Date.now()) / 1000));

                    timerElement.textContent = resendSecondsLeft;

                    if (resendSecondsLeft <= 0) {
                        timerText.style.display = "none";
                        resendButton.disabled = false;
                    }

                    if (otpSecondsLeft <= 0 && resendSecondsLeft <= 0) {
                        clearInterval(timerInterval);
                    }
                }

                const timerInterval = setInterval(updateTimer, 250);
                updateTimer();

                closeButton.addEventListener("click", function () {
                    modal.style.display = "none";
                });
            })();
        </script>
    <% } %>
</body>
</html>
